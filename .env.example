AI_PROVIDER=openrouter
DEMO_FALLBACK_MODE=true

OPENROUTER_API_KEY=
OPENAI_API_KEY=

AI_QUESTION_MODEL=
AI_FAST_MODEL=
AI_STRICT_MODEL=
AI_CHIEF_MODEL=
AI_REWRITE_MODEL=

AI_PROVIDER_SORT=price
AI_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS=2000
AI_REASONING_EFFORT=low

