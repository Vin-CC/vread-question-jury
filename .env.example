# Runtime AI provider: openrouter | openai (alias: codex) | anthropic (alias: claude) | local
AI_PROVIDER=openrouter
# Legacy/internal env name for Local mode.
DEMO_FALLBACK_MODE=true

# Only the key matching AI_PROVIDER is required.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model overrides (apply to the selected provider).
# OpenRouter: openai/gpt-4o-mini … | OpenAI: gpt-4o-mini … | Anthropic: claude-opus-4-8, claude-haiku-4-5 …
AI_QUESTION_MODEL=
AI_FAST_MODEL=
AI_STRICT_MODEL=
AI_CHIEF_MODEL=
AI_REWRITE_MODEL=

AI_PROVIDER_SORT=price
AI_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS=2000
AI_REASONING_EFFORT=low

# Backwards-compatible OpenRouter model variables.
# Generic AI_* variables above take precedence when both are set.
# OPENROUTER_FAST_MODEL=openai/gpt-4o-mini
# OPENROUTER_STRICT_MODEL=openai/gpt-4o-mini
# OPENROUTER_CHIEF_MODEL=openai/gpt-4o-mini
# OPENROUTER_REWRITE_MODEL=openai/gpt-4o-mini
