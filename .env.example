# Runtime AI provider: openrouter | openai (alias: codex) | anthropic (alias: claude) | claude-cli (alias: claude-code)
# claude-cli shells out to the locally installed Claude Code binary and reuses its
# login/subscription — no API key needed. Requires `claude` on PATH (or CLAUDE_CLI_PATH).
AI_PROVIDER=openrouter

# Only the key matching AI_PROVIDER is required (none for claude-cli).
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: absolute path to the claude binary when it is not on the server's PATH.
# CLAUDE_CLI_PATH=

# Model overrides (apply to the selected provider).
# OpenRouter: openai/gpt-4o-mini … | OpenAI: gpt-4o-mini … | Anthropic: claude-opus-4-8, claude-haiku-4-5 …
# claude-cli: CLI aliases (sonnet, opus, haiku) or full model IDs.
AI_QUESTION_MODEL=
AI_FAST_MODEL=
AI_STRICT_MODEL=
AI_CHIEF_MODEL=
AI_REWRITE_MODEL=

AI_PROVIDER_SORT=price
AI_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS=2000
AI_REASONING_EFFORT=low

# Backwards-compatible OpenRouter model variables.
# Generic AI_* variables above take precedence when both are set.
# OPENROUTER_FAST_MODEL=openai/gpt-4o-mini
# OPENROUTER_STRICT_MODEL=openai/gpt-4o-mini
# OPENROUTER_CHIEF_MODEL=openai/gpt-4o-mini
# OPENROUTER_REWRITE_MODEL=openai/gpt-4o-mini
